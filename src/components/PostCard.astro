---
// utils imports
import { formatDate } from "../js/utils";

const { frontmatter, url, /* tagType */ } = Astro.props;
/* const Tag = tagType; */

const { title, description, date, category, author, image } = frontmatter;
---



<div class="author-post">
  <a href={url}>
    <img class="author-post-image" src={image.src} alt={image.alt}>
  </a>
  <h3>
    <a href={url}>{title}</a>
  </h3>
  <span>
    <a href={`/author/${author.slug}/`}>{author.name}</a> • <a href={`/category/${category.slug}/`}>{category.name} • {formatDate(date)}</a> 
  </span>
  <p class="author-post-description">{description}</p>
</div>


<style>
/*   .author-post {
    width: 100%;
  } */
  .author-post-image {
    height: 300px;
    width: 100%;
    object-fit: cover;
    border-radius: 6px;
  }
  .author-post a {
    color: var(--primary-clr-dark);
    text-decoration: none;
  }
  .author-post h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 0.8rem;
    margin-bottom: 0.3rem;
  }

  .author-post-description {
    margin-top: 0.5rem;
    font-size: 1.2rem;
  }
</style>