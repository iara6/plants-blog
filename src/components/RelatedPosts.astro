---
// utils imports
import { slugify } from "../js/utils";

const { relatedPosts } = Astro.props;
---

{
  relatedPosts.map((post) => (
    <div class="related-post">
      <a href={post.url}>
        <img class="related-post-image" src={post.frontmatter.image.src} alt={post.frontmatter.image.alt}>
      </a>
      <h3>
        <a href={post.url}>{post.frontmatter.title}</a>
      </h3>
      <span>
        <a href={`/author/${post.frontmatter.author.slug}/`}>{post.frontmatter.author.name}</a> • <a href={`/category/${slugify(post.frontmatter.category.slug)}/`}>{post.frontmatter.category.name}</a> 
      </span>
    </div>   
  ))
}

<style>
  .related-post-image {
    height: 280px;
    width: 100%;
    object-fit: cover;
  }
  .related-post {
    border-bottom: 1px solid rgb(153, 152, 152, 0.5);
    padding: 1rem 0.5rem;
  }
  .related-post a {
    color: var(--primary-clr-dark);
    text-decoration: none;
  }
  .related-post h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 0.8rem;
  }
</style>