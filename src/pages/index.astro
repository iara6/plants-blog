<style>
  main {
    transition: all 250ms ease;
  }
  h1 {
    background-color: lightpink;
    padding: 3rem;
    font-size: 1.5rem;
    font-weight: 600;
    text-align: center;
    /*  font-family: "Golos Text", sans-serif; */
    font-family: "Commissioner", sans-serif;
    
    /* font-family: "Geologica", sans-serif; */
  }

  p {
    color: var(--primary-clr-dark);
    /* font-size: 1.5rem;  */
    /* font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; */
    padding: 2rem 0;
  }

  .trending-article-container {
    display: flex;
    align-items: center;
    gap: 1rem;
    border: 2px solid hotpink;
  }

  .trending-article_img-wrapper {
    width: 120px;
    height: 120px;
    border: 1px solid red;
    /* object-fit: cover; */
  }

  .trending-article_img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .trending-article-container h3 {
    font-size: 1.3rem;
    font-weight: 600;
  }
  .trending-article-container span {
    font-size: 0.85rem;
    opacity: 0.7;
  }

  .article-category {
    background-color: rgb(181, 242, 181);
    padding: 2px 5px;
    border-radius: 4px;
  }
</style>